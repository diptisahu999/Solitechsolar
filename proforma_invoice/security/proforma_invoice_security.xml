<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_sales_dashboard" model="ir.module.category">
        <field name="name">Sales Dashboard Access</field>
        <field name="sequence">101</field>
    </record>

    <record id="group_sales_dashboard" model="res.groups">
        <field name="name">Dashboard Access</field>
        <field name="category_id" ref="module_category_sales_dashboard"/>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>

    <data noupdate="1">

        <record id="module_category_pi_product_field" model="ir.module.category">
            <field name="name">PI product field access</field>
            <field name="sequence">100</field>
        </record>

        <record id="group_pi_product_field_edit" model="res.groups">
            <field name="name">Yes</field>
            <field name="category_id" ref="module_category_pi_product_field"/>
        </record>

        <record id="proforma_invoice_personal_rule" model="ir.rule">
            <field name="name">Proforma Invoice: Personal Documents</field>
            <field name="model_id" ref="model_proforma_invoice"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="proforma_invoice_manager_rule" model="ir.rule">
            <field name="name">Proforma Invoice: All Documents</field>
            <field name="model_id" ref="model_proforma_invoice"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="proforma_invoice_team_lead_rule" model="ir.rule">
            <field name="name">Proforma Invoice: Team Documents</field>
            <field name="model_id" ref="proforma_invoice.model_proforma_invoice"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', 'in', user.sale_team_id.member_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman_all_leads'))]"/>
        </record>

    </data>
</odoo>